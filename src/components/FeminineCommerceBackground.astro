---
// FeminineCommerceBackground.astro
// A decorative background component for feminine commerce themes
// Uses soft pink/white palette with commerce-themed decorative elements
---

<style>
  .feminine-commerce-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
  }

  .bg-gradient-layer {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #FFF5F8 0%, #FFFFFF 50%, #F7B6CC 100%);
    opacity: 0.9;
  }

  .soft-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    opacity: 0.3;
    animation: float 20s ease-in-out infinite;
  }

  .blob-1 {
    width: 300px;
    height: 300px;
    background: #F7B6CC;
    top: -100px;
    right: 10%;
    animation-delay: 0s;
  }

  .blob-2 {
    width: 250px;
    height: 250px;
    background: #EC8FB1;
    bottom: -50px;
    left: 10%;
    animation-delay: 5s;
  }

  .blob-3 {
    width: 200px;
    height: 200px;
    background: #FFE3ED;
    top: 50%;
    right: 5%;
    animation-delay: 10s;
  }

  .commerce-icons-layer {
    position: absolute;
    inset: 0;
    opacity: 0.15;
  }

  .icon-group {
    position: absolute;
    animation: gentleFloat 15s ease-in-out infinite;
  }

  .icon-heart {
    color: #EC8FB1;
    font-size: 24px;
    animation-delay: 0s;
  }

  .icon-bag {
    color: #F7B6CC;
    font-size: 20px;
    animation-delay: 3s;
  }

  .icon-tag {
    color: #FFE3ED;
    font-size: 18px;
    animation-delay: 6s;
  }

  .icon-star {
    color: #EC8FB1;
    font-size: 16px;
    animation-delay: 9s;
  }

  .icon-gift {
    color: #F7B6CC;
    font-size: 22px;
    animation-delay: 12s;
  }

  .sparkles-layer {
    position: absolute;
    inset: 0;
  }

  .sparkle {
    position: absolute;
    background: white;
    border-radius: 50%;
    opacity: 0.3;
    animation: twinkle 4s ease-in-out infinite;
  }

  .pattern-layer {
    position: absolute;
    inset: 0;
    background-image: 
      radial-gradient(circle at 20% 20%, rgba(247, 182, 204, 0.1) 1px, transparent 1px),
      radial-gradient(circle at 80% 80%, rgba(236, 143, 177, 0.08) 1px, transparent 1px),
      radial-gradient(circle at 40% 60%, rgba(255, 227, 237, 0.12) 1px, transparent 1px);
    background-size: 60px 60px, 80px 80px, 100px 100px;
    opacity: 0.6;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    50% { transform: translateY(-20px) rotate(180deg); }
  }

  @keyframes gentleFloat {
    0%, 100% { transform: translateY(0px) scale(1); }
    50% { transform: translateY(-10px) scale(1.05); }
  }

  @keyframes twinkle {
    0%, 100% { opacity: 0.1; transform: scale(0.5); }
    50% { opacity: 0.8; transform: scale(1.5); }
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .blob-1, .blob-2, .blob-3 {
      filter: blur(40px);
    }
    
    .icon-group {
      opacity: 0.1;
    }
    
    .sparkle {
      opacity: 0.2;
    }
  }
</style>

<div class="feminine-commerce-bg">
  <!-- Soft gradient base layer -->
  <div class="bg-gradient-layer"></div>
  
  <!-- Abstract rounded blob shapes -->
  <div class="soft-blob blob-1"></div>
  <div class="soft-blob blob-2"></div>
  <div class="soft-blob blob-3"></div>
  
  <!-- Commerce-themed icon motifs -->
  <div class="commerce-icons-layer">
    <!-- Top right cluster -->
    <div class="icon-group" style="top: 10%; right: 15%;">
      <span class="icon-heart">❤️</span>
      <span class="icon-bag" style="position: absolute; top: 20px; left: 25px;">🛍️</span>
      <span class="icon-star" style="position: absolute; top: -10px; left: 35px;">⭐</span>
    </div>
    
    <!-- Bottom left cluster -->
    <div class="icon-group" style="bottom: 15%; left: 15%;">
      <span class="icon-gift">🎁</span>
      <span class="icon-tag" style="position: absolute; top: 25px; right: 20px;">🏷️</span>
      <span class="icon-heart" style="position: absolute; top: -15px; right: 30px;">💕</span>
    </div>
    
    <!-- Center decorative elements -->
    <div class="icon-group" style="top: 50%; left: 50%; transform: translate(-50%, -50%);">
      <span class="icon-bag">🛒</span>
      <span class="icon-star" style="position: absolute; top: -15px; left: -20px;">✨</span>
      <span class="icon-star" style="position: absolute; top: -15px; right: -20px;">✨</span>
    </div>
    
    <!-- Floating individual icons -->
    <div class="icon-group icon-heart" style="top: 20%; left: 25%; animation-delay: 2s;">💖</div>
    <div class="icon-group icon-bag" style="top: 70%; right: 25%; animation-delay: 8s;">👜</div>
    <div class="icon-group icon-gift" style="top: 35%; left: 70%; animation-delay: 14s;">🎀</div>
  </div>
  
  <!-- Soft repeated pattern -->
  <div class="pattern-layer"></div>
  
  <!-- Decorative sparkles -->
  <div class="sparkles-layer">
    <div class="sparkle" style="top: 10%; left: 10%; animation-delay: 0s;"></div>
    <div class="sparkle" style="top: 20%; right: 15%; animation-delay: 1s;"></div>
    <div class="sparkle" style="top: 60%; left: 20%; animation-delay: 2s;"></div>
    <div class="sparkle" style="bottom: 20%; right: 25%; animation-delay: 3s;"></div>
    <div class="sparkle" style="top: 80%; left: 60%; animation-delay: 4s;"></div>
    <div class="sparkle" style="bottom: 10%; left: 10%; animation-delay: 5s;"></div>
    <div class="sparkle" style="top: 40%; right: 5%; animation-delay: 6s;"></div>
    <div class="sparkle" style="bottom: 40%; left: 80%; animation-delay: 7s;"></div>
  </div>
</div>